<%- include('../partials/head', { title: 'Reset password' }) %>
<%- include('../partials/nav', { currentUser, isAdmin, active: 'login' }) %>

<%
  const v = (typeof values !== "undefined" && values) ? values : {};
%>

<main class="page">
  <div class="container-wide">
    <div class="page-header">
      <h1 class="page-title">Reset password</h1>
      <p class="page-subtitle">Enter your email, the 6-digit code, and a new password.</p>
    </div>

    <%- include('../partials/alerts') %>

    <div class="card maxw-560">
      <div class="card-body">
        <form method="POST" action="/reset-password" novalidate>
          <div class="form-row">
            <label for="email">Email</label>
            <input
              class="input"
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              value="<%= v.email || '' %>"
            />
          </div>

          <div class="form-row">
            <label for="code">Reset code</label>
            <input
              class="input"
              id="code"
              name="code"
              type="text"
              inputmode="numeric"
              pattern="[0-9]{6}"
              maxlength="6"
              required
              placeholder="123456"
            />
            <div class="help">6 digits (e.g. 123456)</div>
          </div>

          <div class="form-row">
            <label for="password">New password</label>
            <input
              class="input"
              id="password"
              name="password"
              type="password"
              required
              autocomplete="new-password"
            />
            <div class="help">Use at least 6 characters.</div>
          </div>

          <div class="form-row">
            <label for="confirm">Confirm password</label>
            <input
              class="input"
              id="confirm"
              name="confirm"
              type="password"
              required
              autocomplete="new-password"
            />
          </div>

          <div class="form-actions">
            <button class="btn btn-primary" type="submit">Reset password</button>
            <a class="btn btn-secondary" href="/login">Cancel</a>
          </div>
        </form>

        <p class="help mt-14">
          Need a new code? <a href="/forgot-password">Request again</a>
        </p>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
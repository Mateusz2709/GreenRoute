<%- include('../partials/head', { title: 'Register' }) %>
<%- include('../partials/nav', { currentUser, isAdmin, active: 'register' }) %>

<%
  const v = (typeof values !== "undefined" && values) ? values : {};
%>

<main class="page">
  <div class="container-wide">
    <div class="page-header">
      <h1 class="page-title">Create account</h1>
      <p class="page-subtitle">Register to save journeys and review your travel history.</p>
    </div>

    <%- include('../partials/alerts') %>

    <div class="card maxw-560">
      <div class="card-body">
        <form method="POST" action="/register" novalidate>
          <div class="form-row">
            <label for="name">Name</label>
            <input
              class="input"
              id="name"
              name="name"
              type="text"
              required
              autocomplete="name"
              value="<%= v.name || '' %>"
              autofocus
            />
          </div>

          <div class="form-row">
            <label for="email">Email</label>
            <input
              class="input"
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              value="<%= v.email || '' %>"
            />
          </div>

          <div class="form-row">
            <label for="password">Password</label>
            <input
              class="input"
              id="password"
              name="password"
              type="password"
              required
              autocomplete="new-password"
            />
            <div class="help">Use at least 6 characters.</div>
          </div>

          <div class="form-actions">
            <button class="btn btn-primary" type="submit">Create account</button>
            <a class="btn btn-secondary" href="/">Cancel</a>
          </div>
        </form>

        <p class="help mt-14">
          Already have an account? <a href="/login">Login</a>
        </p>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
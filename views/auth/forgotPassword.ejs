<%- include('../partials/head', { title: 'Forgot password' }) %>
<%- include('../partials/nav', { currentUser, isAdmin, active: 'login' }) %>

<%
  const v = (typeof values !== "undefined" && values) ? values : {};
%>

<main class="page">
  <div class="container-wide">
    <div class="page-header">
      <h1 class="page-title">Forgot password</h1>
      <p class="page-subtitle">Enter your email and we will send you a reset code.</p>
    </div>

    <%- include('../partials/alerts') %>

    <div class="card maxw-560">
      <div class="card-body">
        <form method="POST" action="/forgot-password" novalidate>
          <div class="form-row">
            <label for="email">Email</label>
            <input
              class="input"
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              value="<%= v.email || '' %>"
            />
          </div>

          <div class="form-actions">
            <button class="btn btn-primary" type="submit">Send code</button>
            <a class="btn btn-secondary" href="/login">Back</a>
          </div>
        </form>

        <p class="help mt-14">
          Already have a code? <a href="/reset-password">Reset password</a>
        </p>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>